// Windows-specific devcontainer configuration.
// Use this variant when opening the workspace from a Windows host.
{
	"name": "Node.js & TypeScript (Windows)",
	"image": "mcr.microsoft.com/devcontainers/typescript-node:4-24-trixie",
	"features": {
		"ghcr.io/devcontainers/features/terraform:1": {}
	},
	"mounts": [
		"source=${localEnv:USERPROFILE}/.npm,target=/home/node/.npm,type=bind,consistency=cached"
	],
	"runArgs": [
		"--cap-add=SYS_PTRACE",
		"--cap-add=NET_ADMIN"
	],
	"remoteEnv": {
		"NODE_ENV": "development",
		"npm_config_loglevel": "warn",
		"npm_config_progress": "false"
	},
	"customizations": {
		"vscode": {
			"extensions": [
				"kilocode.kilo-code"
			]
		}
	}
}